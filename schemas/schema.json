{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "status",
    "severity",
    "author",
    "date",
    "mitre",
    "data_sources",
    "query",
    "query_frequency",
    "query_period",
    "trigger_operator",
    "trigger_threshold",
    "validation"
  ],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["experimental", "test", "production"]
    },
    "severity": {
      "type": "string",
      "enum": ["Low", "Medium", "High", "Critical"]
    },
    "author": { "type": "string" },
    "date": { "type": "string" },
    "mitre": {
      "type": "object",
      "required": ["tactics", "techniques"],
      "properties": {
        "tactics": { "type": "array", "items": { "type": "string" } },
        "techniques": { "type": "array", "items": { "type": "string" } }
      }
    },
    "data_sources": { "type": "array", "items": { "type": "string" } },
    "query": { "type": "string" },
    "query_frequency": { "type": "string" },
    "query_period": { "type": "string" },
    "trigger_operator": { "type": "string" },
    "trigger_threshold": { "type": "number" },
    "false_positives": { "type": "array", "items": { "type": "string" } },
    "validation": {
      "type": "object",
      "required": ["trigger_action", "expected_result"],
      "properties": {
        "trigger_action": { "type": "string" },
        "expected_result": { "type": "string" },
        "last_validated": { "type": "string" }
      }
    }
  }
}
